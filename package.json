{
  "name": "reference-photo-organizer",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based artist reference board with local image tagging, palettes, collages, and PNG/PDF export.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/clean-pages.mjs && tsc -b && vite build && node scripts/copy-404.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint . --max-warnings=0",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@tanstack/react-query": "^5.90.10",
    "comlink": "^4.4.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "quantize": "^1.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.13"
  }
}
